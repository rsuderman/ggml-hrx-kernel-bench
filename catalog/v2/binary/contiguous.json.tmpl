{
  "id": "${route_id}",
  "family": "${family}",
  "kernel": {
    "source_id": "${source_id}",
    "path": "${kernel_path}",
    "root_symbol": "${root_symbol}",
    "export_name": "${export_name}"
  },
  "tensors": {
    "src0": {
      "dtype": "${dtype}",
      "dimensions": "src0_dimensions",
      "strides": "src0_strides"
    },
    "src1": {
      "dtype": "${dtype}",
      "dimensions": "src1_dimensions",
      "strides": "src1_strides"
    },
    "dst": {
      "dtype": "${dtype}",
      "dimensions": "dst_dimensions",
      "strides": "dst_strides"
    }
  },
  "values": [
    {
      "name": "contiguous_strides",
      "contiguous_strides": "dst_dimensions"
    },
    {
      "name": "total_size",
      "product": "dst_dimensions"
    }
  ],
  "constraints": [
    {
      "name": "total_size",
      "min": 1,
      "max": 1073741824
    },
    {
      "name": "dst_dimensions",
      "rank_min": 1,
      "rank_max": 4
    },
    {
      "equals": [
        "src0_dimensions",
        "src1_dimensions",
        "dst_dimensions"
      ]
    },
    {
      "equals": [
        "contiguous_strides",
        "src0_strides",
        "src1_strides",
        "dst_strides"
      ]
    }
  ],
  "launch": {
    "workgroup_size": [
      256,
      1,
      1
    ],
    "max_workgroups_x": 65535
  },
  "config": {
    "bindings": [
      {
        "key": "@hrx2.shape.pointwise.total_size",
        "source": "value.total_size"
      },
      {
        "key": "@hrx2.tuning.pointwise.workgroup_size",
        "value": "256"
      }
    ]
  }
}

{
  "id": "rms_norm_f32_contiguous_4d",
  "family": "rms_norm_f32",
  "kernel": {
    "source_id": "rms_norm_f32",
    "path": "rms_norm/contiguous_4d.loom",
    "root_symbol": "@hrx2_rms_norm_f32",
    "export_name": "hrx2_rms_norm_f32"
  },
  "tensors": {
    "src0": {
      "dtype": "F32",
      "dimensions": "src0_dimensions",
      "strides": "src0_strides"
    },
    "dst": {
      "dtype": "F32",
      "dimensions": "dst_dimensions",
      "strides": "dst_strides"
    }
  },
  "values": [
    {
      "name": "contiguous_strides",
      "contiguous_strides": "dst_dimensions"
    },
    {
      "name": "trailing_dimensions",
      "tail": {
        "source": "dst_dimensions",
        "drop": 1
      }
    },
    {
      "name": "flattened_trailing_dimensions",
      "product": "trailing_dimensions"
    },
    {
      "name": "total_size",
      "product": "dst_dimensions"
    }
  ],
  "constraints": [
    {
      "name": "total_size",
      "min": 1,
      "max": 1073741824
    },
    {
      "name": "dst_dimensions",
      "length": 4
    },
    {
      "equals": [
        "src0_dimensions",
        "dst_dimensions"
      ]
    },
    {
      "equals": [
        "contiguous_strides",
        "src0_strides",
        "dst_strides"
      ]
    }
  ],
  "launch": {
    "workgroup_count_source": "value.flattened_trailing_dimensions",
    "workgroup_size": [
      32,
      1,
      1
    ]
  },
  "config": {
    "bindings": [
      {
        "key": "@hrx2.shape.rms_norm.ncols",
        "source": "tensor.dst.dimensions.d0.size"
      },
      {
        "key": "@hrx2.shape.rms_norm.nrows",
        "source": "value.flattened_trailing_dimensions"
      },
      {
        "key": "@hrx2.tuning.rms_norm.workgroup_size",
        "value": "32"
      }
    ]
  }
}

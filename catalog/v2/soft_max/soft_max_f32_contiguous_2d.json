{
  "id": "soft_max_f32_contiguous_2d",
  "family": "soft_max_f32",
  "kernel": {
    "source_id": "soft_max_f32",
    "path": "soft_max/contiguous_f32.loom",
    "root_symbol": "@hrx2_soft_max_f32",
    "export_name": "hrx2_soft_max_f32"
  },
  "tensors": {
    "src0": {
      "dtype": "F32",
      "dimensions": "src0_dimensions",
      "strides": "src0_strides"
    },
    "dst": {
      "dtype": "F32",
      "dimensions": "dst_dimensions",
      "strides": "dst_strides"
    }
  },
  "values": [
    {
      "name": "contiguous_strides",
      "contiguous_strides": "dst_dimensions"
    },
    {
      "name": "total_size",
      "product": "dst_dimensions"
    }
  ],
  "constraints": [
    {
      "name": "total_size",
      "min": 1,
      "max": 1073741824
    },
    {
      "name": "src0_dimensions",
      "length": 2
    },
    {
      "name": "dst_dimensions",
      "length": 2
    },
    {
      "name": "dst_dimensions",
      "index": 0,
      "min": 1,
      "max": 1024
    },
    {
      "name": "dst_dimensions",
      "index": 1,
      "min": 1,
      "max": 1048576
    },
    {
      "equals": [
        "src0_dimensions",
        "dst_dimensions"
      ]
    },
    {
      "equals": [
        "contiguous_strides",
        "src0_strides",
        "dst_strides"
      ]
    }
  ],
  "launch": {
    "workgroup_size": [
      1024,
      1,
      1
    ]
  },
  "config": {
    "bindings": [
      {
        "key": "@shape.soft_max.ncols",
        "source": "tensor.dst.dimensions.d0.size"
      },
      {
        "key": "@shape.soft_max.nrows",
        "source": "tensor.dst.dimensions.d1.size"
      },
      {
        "key": "@tuning.soft_max.workgroup_size",
        "value": "1024"
      }
    ]
  }
}

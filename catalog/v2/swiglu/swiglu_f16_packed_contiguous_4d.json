{
  "id": "swiglu_f16_packed_contiguous_4d",
  "family": "swiglu_f16",
  "op": "SWIGLU",
  "kernel": {
    "source_id": "swiglu_f16",
    "path": "swiglu/contiguous_f16_4d.loom",
    "root_symbol": "@hrx2_swiglu_f16",
    "export_name": "hrx2_swiglu_f16"
  },
  "attributes": {
    "swapped": {
      "type": "i32"
    }
  },
  "tensors": {
    "src0": {
      "dtype": "F16",
      "dimensions": "src0_dimensions",
      "strides": "src0_strides"
    },
    "dst": {
      "dtype": "F16",
      "dimensions": "dst_dimensions",
      "strides": "dst_strides"
    }
  },
  "values": [
    {
      "name": "src0_contiguous_strides",
      "contiguous_strides": "src0_dimensions"
    },
    {
      "name": "dst_contiguous_strides",
      "contiguous_strides": "dst_dimensions"
    },
    {
      "name": "src0_trailing_dimensions",
      "tail": {
        "source": "src0_dimensions",
        "drop": 1
      }
    },
    {
      "name": "dst_trailing_dimensions",
      "tail": {
        "source": "dst_dimensions",
        "drop": 1
      }
    },
    {
      "name": "ncols_dims",
      "head": {
        "source": "dst_dimensions",
        "take": 1
      }
    },
    {
      "name": "ncols",
      "product": "ncols_dims"
    },
    {
      "name": "flattened_trailing_dimensions",
      "product": "dst_trailing_dimensions"
    },
    {
      "name": "total_size",
      "product": "dst_dimensions"
    }
  ],
  "constraints": [
    {
      "name": "total_size",
      "min": 1,
      "max": 1073741824
    },
    {
      "name": "src0_dimensions",
      "length": 4
    },
    {
      "name": "dst_dimensions",
      "length": 4
    },
    {
      "name": "attribute.swapped",
      "min": 0,
      "max": 1
    },
    {
      "name": "ncols",
      "min": 64,
      "max": 65536
    },
    {
      "equals": [
        "src0_trailing_dimensions",
        "dst_trailing_dimensions"
      ]
    },
    {
      "equals": [
        "src0_contiguous_strides",
        "src0_strides"
      ]
    },
    {
      "equals": [
        "dst_contiguous_strides",
        "dst_strides"
      ]
    }
  ],
  "launch": {
    "workgroup_size": [
      256,
      1,
      1
    ]
  },
  "config": {
    "bindings": [
      {
        "key": "@shape.swiglu.ncols",
        "source": "tensor.dst.dimensions.d0.size"
      },
      {
        "key": "@shape.swiglu.nrows",
        "source": "value.flattened_trailing_dimensions"
      },
      {
        "key": "@shape.swiglu.swapped",
        "source": "attribute.swapped"
      },
      {
        "key": "@tuning.swiglu.workgroup_size",
        "value": "256"
      }
    ]
  }
}

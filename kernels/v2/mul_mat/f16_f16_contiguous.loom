config.decl @shape.mul_mat_f16_f16_contiguous.k : %value: index where [range(%value, 1, 104857600)]
config.decl @shape.mul_mat_f16_f16_contiguous.rows : %value: index where [range(%value, 1, 104857600)]
config.decl @shape.mul_mat_f16_f16_contiguous.cols : %value: index where [range(%value, 1, 104857600)]
config.decl @shape.mul_mat_f16_f16_contiguous.batch2 : %value: index where [range(%value, 1, 104857600)]
config.decl @shape.mul_mat_f16_f16_contiguous.batch3 : %value: index where [range(%value, 1, 104857600)]
config.decl @tuning.mul_mat_f16_f16_contiguous.workgroup_size : %value: index where [range(%value, 32, 1024), mul(%value, 32)]

kernel.def export("hrx2_mul_mat_f16_f16_contiguous") @hrx2_mul_mat_f16_f16_contiguous() {
  %unit = index.constant 1 : index
  %rows = config.get @shape.mul_mat_f16_f16_contiguous.rows : index
  %cols = config.get @shape.mul_mat_f16_f16_contiguous.cols : index
  %batch2 = config.get @shape.mul_mat_f16_f16_contiguous.batch2 : index
  %batch3 = config.get @shape.mul_mat_f16_f16_contiguous.batch3 : index
  %workgroup_size = config.get @tuning.mul_mat_f16_f16_contiguous.workgroup_size : index
  %outer0 = index.mul %cols, %batch2 : index
  %outer = index.mul %outer0, %batch3 : index
  kernel.launch.config workgroups(%rows, %outer, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch(%src0: buffer, %src1: buffer, %dst: buffer) {
  %base = index.constant 0 : offset
  %zero_index = index.constant 0 : index
  %unit = index.constant 1 : index
  %zero_f32 = scalar.constant 0.0 : f32

  %k = config.get @shape.mul_mat_f16_f16_contiguous.k : index
  %rows = config.get @shape.mul_mat_f16_f16_contiguous.rows : index
  %cols = config.get @shape.mul_mat_f16_f16_contiguous.cols : index
  %batch2 = config.get @shape.mul_mat_f16_f16_contiguous.batch2 : index
  %batch3 = config.get @shape.mul_mat_f16_f16_contiguous.batch3 : index
  %workgroup_size = config.get @tuning.mul_mat_f16_f16_contiguous.workgroup_size : index

  %row = kernel.workgroup.id<x> : index
  %outer = kernel.workgroup.id<y> : index
  %lane = kernel.workitem.id<x> : index

  %col = index.rem %outer, %cols : index
  %batch_linear = index.div %outer, %cols : index
  %i2 = index.rem %batch_linear, %batch2 : index
  %i3 = index.div %batch_linear, %batch2 : index

  %src0_batch2_stride = index.mul %k, %rows : index
  %src0_batch3_stride = index.mul %src0_batch2_stride, %batch2 : index
  %src0_count = index.mul %src0_batch3_stride, %batch3 : index

  %src1_batch2_stride = index.mul %k, %cols : index
  %src1_batch3_stride = index.mul %src1_batch2_stride, %batch2 : index
  %src1_count = index.mul %src1_batch3_stride, %batch3 : index

  %dst_batch2_stride = index.mul %rows, %cols : index
  %dst_batch3_stride = index.mul %dst_batch2_stride, %batch2 : index
  %dst_count = index.mul %dst_batch3_stride, %batch3 : index

  %src0_global = buffer.assume.memory_space<global> %src0 : buffer
  %src1_global = buffer.assume.memory_space<global> %src1 : buffer
  %dst_global = buffer.assume.memory_space<global> %dst : buffer
  %src0_restrict, %src1_restrict, %dst_restrict = buffer.assume.noalias %src0_global, %src1_global, %dst_global : buffer, buffer, buffer
  %src0_view = buffer.view %src0_restrict[%base] : buffer -> view<[%src0_count]xf16, #dense>
  %src1_view = buffer.view %src1_restrict[%base] : buffer -> view<[%src1_count]xf16, #dense>
  %dst_view = buffer.view %dst_restrict[%base] : buffer -> view<[%dst_count]xf32, #dense>

  %src0_row_off = index.mul %row, %k : index
  %src0_i2_off = index.mul %i2, %src0_batch2_stride : index
  %src0_i3_off = index.mul %i3, %src0_batch3_stride : index
  %src0_base0 = index.add %src0_row_off, %src0_i2_off : index
  %src0_base = index.add %src0_base0, %src0_i3_off : index

  %src1_col_off = index.mul %col, %k : index
  %src1_i2_off = index.mul %i2, %src1_batch2_stride : index
  %src1_i3_off = index.mul %i3, %src1_batch3_stride : index
  %src1_base0 = index.add %src1_col_off, %src1_i2_off : index
  %src1_base = index.add %src1_base0, %src1_i3_off : index

  %is_leader = index.cmp eq, %lane, %zero_index : index
  %lane_sum = scf.for %ki = [%lane to %k step %workgroup_size](%acc = %zero_f32 : f32) -> (f32) {
    %src0_index = index.add %src0_base, %ki : index
    %src1_index = index.add %src1_base, %ki : index
    %a_f16 = view.load %src0_view[%src0_index] : view<[%src0_count]xf16, #dense> -> f16
    %b_f16 = view.load %src1_view[%src1_index] : view<[%src1_count]xf16, #dense> -> f16
    %a = scalar.extf %a_f16 : f16 to f32
    %b = scalar.extf %b_f16 : f16 to f32
    %product = scalar.mulf<reassoc|nnan|ninf|nsz|contract> %a, %b : f32
    %next = scalar.addf<reassoc|nnan|ninf|nsz> %acc, %product : f32
    scf.yield %next : f32
  }

  %dot = kernel.workgroup.reduce<addf> %lane_sum : f32
  scf.if %is_leader {
    %dst_col_off = index.mul %col, %rows : index
    %dst_i2_off = index.mul %i2, %dst_batch2_stride : index
    %dst_i3_off = index.mul %i3, %dst_batch3_stride : index
    %dst_index0 = index.add %row, %dst_col_off : index
    %dst_index1 = index.add %dst_index0, %dst_i2_off : index
    %dst_index = index.add %dst_index1, %dst_i3_off : index
    view.store %dot, %dst_view[%dst_index] : f32, view<[%dst_count]xf32, #dense>
  }
  kernel.return
}

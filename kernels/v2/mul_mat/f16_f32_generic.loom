config.decl @shape.mul_mat_f16_f32_generic.k : %value: index where [range(%value, 1, 8192)]
config.decl @shape.mul_mat_f16_f32_generic.rows : %value: index where [range(%value, 1, 8192)]
config.decl @shape.mul_mat_f16_f32_generic.cols : %value: index where [range(%value, 1, 4096)]

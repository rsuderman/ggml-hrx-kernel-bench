    %q21f = scalar.uitofp %q21 : i32 to f32
    %q22f = scalar.uitofp %q22 : i32 to f32
    %q23f = scalar.uitofp %q23 : i32 to f32
    %q30f = scalar.uitofp %q30 : i32 to f32
    %q31f = scalar.uitofp %q31 : i32 to f32
    %q32f = scalar.uitofp %q32 : i32 to f32
    %q33f = scalar.uitofp %q33 : i32 to f32
    %q0v = vector.from_elements %q00f, %q01f, %q02f, %q03f : vector<4xf32>
    %q1v = vector.from_elements %q10f, %q11f, %q12f, %q13f : vector<4xf32>
    %q2v = vector.from_elements %q20f, %q21f, %q22f, %q23f : vector<4xf32>
    %q3v = vector.from_elements %q30f, %q31f, %q32f, %q33f : vector<4xf32>
    %by0v = vector.from_elements %by0x, %by0y, %by16x, %by16y : vector<4xf32>
    %by1v = vector.from_elements %by32x, %by32y, %by48x, %by48y : vector<4xf32>
    %by2v = vector.from_elements %by128x, %by128y, %by144x, %by144y : vector<4xf32>
    %by3v = vector.from_elements %by160x, %by160y, %by176x, %by176y : vector<4xf32>
    %prod0 = vector.mulf<reassoc|nnan|ninf|nsz> %q0v, %by0v : vector<4xf32>
    %prod1 = vector.mulf<reassoc|nnan|ninf|nsz> %q1v, %by1v : vector<4xf32>
    %prod2 = vector.mulf<reassoc|nnan|ninf|nsz> %q2v, %by2v : vector<4xf32>
    %prod3 = vector.mulf<reassoc|nnan|ninf|nsz> %q3v, %by3v : vector<4xf32>
    %sx = vector.reduce<addf, reassoc|nnan|ninf|nsz> %prod0, %zero_f32 : vector<4xf32>, f32
    %sy = vector.reduce<addf, reassoc|nnan|ninf|nsz> %prod1, %zero_f32 : vector<4xf32>, f32
    %sz = vector.reduce<addf, reassoc|nnan|ninf|nsz> %prod2, %zero_f32 : vector<4xf32>, f32
    %sw = vector.reduce<addf, reassoc|nnan|ninf|nsz> %prod3, %zero_f32 : vector<4xf32>, f32

    %by0_sum0 = scalar.addf<reassoc|nnan|ninf|nsz> %by0x, %by0y : f32
    %by0_sum1 = scalar.addf<reassoc|nnan|ninf|nsz> %by16x, %by16y : f32
    %by0_sum = scalar.addf<reassoc|nnan|ninf|nsz> %by0_sum0, %by0_sum1 : f32
    %by1_sum0 = scalar.addf<reassoc|nnan|ninf|nsz> %by32x, %by32y : f32
    %by1_sum1 = scalar.addf<reassoc|nnan|ninf|nsz> %by48x, %by48y : f32
    %by1_sum = scalar.addf<reassoc|nnan|ninf|nsz> %by1_sum0, %by1_sum1 : f32
    %by2_sum0 = scalar.addf<reassoc|nnan|ninf|nsz> %by128x, %by128y : f32
    %by2_sum1 = scalar.addf<reassoc|nnan|ninf|nsz> %by144x, %by144y : f32
    %by2_sum = scalar.addf<reassoc|nnan|ninf|nsz> %by2_sum0, %by2_sum1 : f32
    %by3_sum0 = scalar.addf<reassoc|nnan|ninf|nsz> %by160x, %by160y : f32
    %by3_sum1 = scalar.addf<reassoc|nnan|ninf|nsz> %by176x, %by176y : f32
    %by3_sum = scalar.addf<reassoc|nnan|ninf|nsz> %by3_sum0, %by3_sum1 : f32

    %scale_a_i = scalar.andi %scale_0_4_l6, %mask_ff : i32
    %scale_b_s = scalar.shrui %scale_0_4_l6, %eight_i32 : i32
    %scale_b_i = scalar.andi %scale_b_s, %mask_ff : i32
    %min_a_s = scalar.shrui %scale_0_4_l6, %sixteen_i32 : i32
    %min_a_i = scalar.andi %min_a_s, %mask_ff : i32
    %min_b_s = scalar.shrui %scale_0_4_l6, %twentyfour_i32 : i32
    %min_b_i = scalar.andi %min_b_s, %mask_ff : i32
    %scale_c_i = scalar.andi %scale8, %mask_ff : i32
    %scale_d_s = scalar.shrui %scale8, %eight_i32 : i32
    %scale_d_i = scalar.andi %scale_d_s, %mask_ff : i32
    %min_c_s = scalar.shrui %scale8, %sixteen_i32 : i32
    %min_c_i = scalar.andi %min_c_s, %mask_ff : i32
    %min_d_s = scalar.shrui %scale8, %twentyfour_i32 : i32
    %min_d_i = scalar.andi %min_d_s, %mask_ff : i32
    %scale_a = scalar.uitofp %scale_a_i : i32 to f32
    %scale_b = scalar.uitofp %scale_b_i : i32 to f32
    %scale_c = scalar.uitofp %scale_c_i : i32 to f32
    %scale_d = scalar.uitofp %scale_d_i : i32 to f32
    %min_a = scalar.uitofp %min_a_i : i32 to f32
    %min_b = scalar.uitofp %min_b_i : i32 to f32
    %min_c = scalar.uitofp %min_c_i : i32 to f32
    %min_d = scalar.uitofp %min_d_i : i32 to f32
    %sum_d0 = scalar.mulf<reassoc|nnan|ninf|nsz> %sw, %scale_d : f32
    %sum_d1 = scalar.fmaf<reassoc|nnan|ninf|nsz> %sz, %scale_c, %sum_d0 : f32
    %sum_d2 = scalar.fmaf<reassoc|nnan|ninf|nsz> %sy, %scale_b, %sum_d1 : f32
    %sum_d3 = scalar.fmaf<reassoc|nnan|ninf|nsz> %sx, %scale_a, %sum_d2 : f32
    %smin0 = scalar.mulf<reassoc|nnan|ninf|nsz> %by0_sum, %min_a : f32
    %smin1 = scalar.fmaf<reassoc|nnan|ninf|nsz> %by1_sum, %min_b, %smin0 : f32
    %smin2 = scalar.fmaf<reassoc|nnan|ninf|nsz> %by2_sum, %min_c, %smin1 : f32
    %smin = scalar.fmaf<reassoc|nnan|ninf|nsz> %by3_sum, %min_d, %smin2 : f32
    %neg_dmin = scalar.subf<reassoc|nnan|ninf|nsz> %zero_f32, %dmin : f32
    %minus_dmin_smin = scalar.mulf<reassoc|nnan|ninf|nsz> %neg_dmin, %smin : f32
    %dot_block = scalar.fmaf<reassoc|nnan|ninf|nsz> %d, %sum_d3, %minus_dmin_smin : f32
    %acc_next = scalar.addf<reassoc|nnan|ninf|nsz> %acc, %dot_block : f32
    scf.yield %acc_next : f32
  }

  %dot = kernel.workgroup.reduce<addf> %sum : f32
  %dst_col_base = index.mul %col, %rows_bounded : index
  %dst_index = index.add %dst_col_base, %row : index
  %lane_i32 = index.cast %lane : index to i32
  %is_lane0 = scalar.cmpi eq, %lane_i32, %zero_i32 : i32
  scf.if %is_lane0 {
    view.store %dot, %dst_view[%dst_index] : f32, view<[%dst_count]xf32, #dense>
  }
  kernel.return
}

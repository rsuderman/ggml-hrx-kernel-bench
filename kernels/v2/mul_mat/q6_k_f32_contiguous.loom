config.decl @shape.mul_mat_q6_k_f32_contiguous.k : %value: index where [range(%value, 256, 32768), mul(%value, 256)]
config.decl @shape.mul_mat_q6_k_f32_contiguous.rows : %value: index where [range(%value, 1, 262144)]
config.decl @shape.mul_mat_q6_k_f32_contiguous.cols : %value: index where [range(%value, 1, 1024)]
config.decl @tuning.mul_mat_q6_k_f32_contiguous.workgroup_size : %value: index where [range(%value, 32, 256), mul(%value, 32)]

kernel.def export("hrx2_mul_mat_q6_k_f32_contiguous") @hrx2_mul_mat_q6_k_f32_contiguous() {
  %unit = index.constant 1 : index
  %rows = config.get @shape.mul_mat_q6_k_f32_contiguous.rows : index
  %cols = config.get @shape.mul_mat_q6_k_f32_contiguous.cols : index
  %workgroup_size = config.get @tuning.mul_mat_q6_k_f32_contiguous.workgroup_size : index
  kernel.launch.config workgroups(%rows, %cols, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch(%src0: buffer, %src1: buffer, %dst: buffer) {
  %base = index.constant 0 : offset
  %zero_index = index.constant 0 : index
  %one = index.constant 1 : index
  %two = index.constant 2 : index
  %four = index.constant 4 : index
  %eight = index.constant 8 : index
  %sixteen = index.constant 16 : index
  %thirtytwo = index.constant 32 : index
  %sixtyfour = index.constant 64 : index
  %onetwentyeight = index.constant 128 : index
  %qk = index.constant 256 : index
  %block_bytes = index.constant 210 : index
  %block_f16s = index.constant 105 : index
  %qh_offset = index.constant 128 : index
  %scales_offset = index.constant 192 : index
  %d_f16_offset = index.constant 104 : index
  %mask_0f = scalar.constant 15 : i32
  %mask_03 = scalar.constant 3 : i32
  %two_i32 = scalar.constant 2 : i32
  %four_i32 = scalar.constant 4 : i32
  %thirtytwo_i32 = scalar.constant 32 : i32
  %zero_f32 = scalar.constant 0.0 : f32
  %k = config.get @shape.mul_mat_q6_k_f32_contiguous.k : index
  %rows = config.get @shape.mul_mat_q6_k_f32_contiguous.rows : index
  %cols = config.get @shape.mul_mat_q6_k_f32_contiguous.cols : index
  %workgroup_size = config.get @tuning.mul_mat_q6_k_f32_contiguous.workgroup_size : index
  %k_bounded = index.assume %k [range(%k, 256, 32768)] : index
  %rows_bounded = index.assume %rows [range(%rows, 1, 262144)] : index
  %cols_bounded = index.assume %cols [range(%cols, 1, 512)] : index
  %row0 = kernel.workgroup.id<x> : index
  %row = index.assume %row0 [range(%row0, 0, 262143)] : index
  %col0 = kernel.workgroup.id<y> : index
  %col = index.assume %col0 [range(%col0, 0, 511)] : index
  %lane0 = kernel.workitem.id<x> : index
  %lane = index.assume %lane0 [range(%lane0, 0, 31)] : index

  %blocks_per_row = index.div %k_bounded, %qk : index
  %total_blocks = index.mul %rows_bounded, %blocks_per_row : index
  %src0_i8_count = index.mul %total_blocks, %block_bytes : index
  %src0_f16_count = index.mul %total_blocks, %block_f16s : index
  %src1_count = index.mul %cols_bounded, %k_bounded : index
  %dst_count = index.mul %cols_bounded, %rows_bounded : index
  %lane_div16 = index.div %lane, %sixteen : index

  %src0_global = buffer.assume.memory_space<descriptor> %src0 : buffer
  %src1_global = buffer.assume.memory_space<descriptor> %src1 : buffer
  %dst_global = buffer.assume.memory_space<descriptor> %dst : buffer
  %src0_noalias, %src1_noalias, %dst_noalias = buffer.assume.noalias %src0_global, %src1_global, %dst_global : buffer, buffer, buffer
  %src0_i8_view = buffer.view %src0_noalias[%base] : buffer -> view<[%src0_i8_count]xi8, #dense>
  %src0_f16_view = buffer.view %src0_noalias[%base] : buffer -> view<[%src0_f16_count]xf16, #dense>
  %src1_view = buffer.view %src1_noalias[%base] : buffer -> view<[%src1_count]xf32, #dense>
  %dst_view = buffer.view %dst_noalias[%base] : buffer -> view<[%dst_count]xf32, #dense>

  %row_block_base = index.mul %row, %blocks_per_row : index
  %src1_col_base = index.mul %col, %k_bounded : index
  %sum = scf.for %block_idx = [%zero_index to %blocks_per_row step %one](%acc = %zero_f32 : f32) -> (f32) {
    %src_base_block = index.mul %block_idx, %qk : index
    %linear_block = index.add %row_block_base, %block_idx : index
    %block_byte_base = index.mul %linear_block, %block_bytes : index
    %block_f16_base = index.mul %linear_block, %block_f16s : index
    %d_index = index.add %block_f16_base, %d_f16_offset : index
    %d_f16 = view.load %src0_f16_view[%d_index] : view<[%src0_f16_count]xf16, #dense> -> f16
    %d = scalar.extf %d_f16 : f16 to f32

    %next = scf.for %part = [%zero_index to %eight step %one](%inner = %acc : f32) -> (f32) {
      %half = index.div %part, %four : index
      %segment = index.rem %part, %four : index
      %half64 = index.mul %half, %sixtyfour : index
      %ql_lane_base = index.add %half64, %lane : index
      %segment_mod2 = index.rem %segment, %two : index
      %ql_pair_add = index.mul %segment_mod2, %thirtytwo : index
      %ql_lane = index.add %ql_lane_base, %ql_pair_add : index
      %ql_byte_index = index.add %block_byte_base, %ql_lane : index
      %ql_i8 = view.load %src0_i8_view[%ql_byte_index] : view<[%src0_i8_count]xi8, #dense> -> i8
      %ql_byte = scalar.extui %ql_i8 : i8 to i32
      %segment_div2 = index.div %segment, %two : index
      %ql_shift_index = index.mul %segment_div2, %four : index
      %ql_shift = index.cast %ql_shift_index : index to i32
      %ql_shifted = scalar.shrui %ql_byte, %ql_shift : i32
      %ql_nibble = scalar.andi %ql_shifted, %mask_0f : i32
      %half32 = index.mul %half, %thirtytwo : index
      %qh_lane_base = index.add %half32, %lane : index
      %qh_block_base0 = index.add %block_byte_base, %qh_offset : index
      %qh_byte_index = index.add %qh_block_base0, %qh_lane_base : index
      %qh_i8 = view.load %src0_i8_view[%qh_byte_index] : view<[%src0_i8_count]xi8, #dense> -> i8
      %qh_byte = scalar.extui %qh_i8 : i8 to i32
      %segment_i32 = index.cast %segment : index to i32
      %qh_shift = scalar.muli %segment_i32, %two_i32 : i32
      %qh_shifted = scalar.shrui %qh_byte, %qh_shift : i32
      %qh_bits = scalar.andi %qh_shifted, %mask_03 : i32
      %qh_hi = scalar.shli %qh_bits, %four_i32 : i32
      %q_u = scalar.ori %ql_nibble, %qh_hi : i32
      %q_i32 = scalar.subi %q_u, %thirtytwo_i32 : i32
      %q_f32 = scalar.sitofp %q_i32 : i32 to f32
      %half8 = index.mul %half, %eight : index
      %scale_part_add = index.mul %segment, %two : index
      %scale_base0 = index.add %half8, %lane_div16 : index
      %scale_lane = index.add %scale_base0, %scale_part_add : index
      %scale_block_base = index.add %block_byte_base, %scales_offset : index
      %scale_index = index.add %scale_block_base, %scale_lane : index
      %scale_i8 = view.load %src0_i8_view[%scale_index] : view<[%src0_i8_count]xi8, #dense> -> i8
      %scale_i32 = scalar.extsi %scale_i8 : i8 to i32
      %scale_f32 = scalar.sitofp %scale_i32 : i32 to f32
      %half128 = index.mul %half, %onetwentyeight : index
      %src_part_add = index.mul %segment, %thirtytwo : index
      %src_part_base0 = index.add %half128, %src_part_add : index
      %src_part = index.add %src_part_base0, %lane : index
      %src_offset = index.add %src_base_block, %src_part : index
      %src1_index = index.add %src1_col_base, %src_offset : index
      %rhs = view.load %src1_view[%src1_index] : view<[%src1_count]xf32, #dense> -> f32
      %dq0 = scalar.mulf %d, %scale_f32 : f32
      %dq = scalar.mulf %dq0, %q_f32 : f32
      %product = scalar.mulf %dq, %rhs : f32
      %acc_next = scalar.addf %inner, %product : f32
      scf.yield %acc_next : f32
    }
    scf.yield %next : f32
  }

  %dot = kernel.workgroup.reduce<addf> %sum : f32
  %dst_col_base = index.mul %col, %rows_bounded : index
  %dst_index = index.add %dst_col_base, %row : index
  %lane_i32 = index.cast %lane : index to i32
  %zero_i32 = scalar.constant 0 : i32
  %is_lane0 = scalar.cmpi eq, %lane_i32, %zero_i32 : i32
  scf.if %is_lane0 {
    view.store %dot, %dst_view[%dst_index] : f32, view<[%dst_count]xf32, #dense>
  }
  kernel.return
}

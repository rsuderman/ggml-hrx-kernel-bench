config.decl @shape.mul_mat_q8_0_f32_contiguous_c4.k : %value: index where [range(%value, 32, 32768), mul(%value, 32)]
config.decl @shape.mul_mat_q8_0_f32_contiguous_c4.rows : %value: index where [range(%value, 1, 262144)]
config.decl @shape.mul_mat_q8_0_f32_contiguous_c4.cols : %value: index where [range(%value, 4, 4096), mul(%value, 4)]
config.decl @tuning.mul_mat_q8_0_f32_contiguous_c4.workgroup_size : %value: index where [range(%value, 32, 256), mul(%value, 32)]

func.template<hrx2.q8_0_f32.c4.product> priority(1) @q8_0_f32_c4_product_fallback(%q: i8, %d_f16: f16, %rhs: f32) -> (f32) {
  %q_f32 = scalar.sitofp %q : i8 to f32
  %d = scalar.extf %d_f16 : f16 to f32
  %scaled = scalar.mulf<reassoc|nnan|ninf|nsz> %q_f32, %d : f32
  %product = scalar.mulf<reassoc|nnan|ninf|nsz> %scaled, %rhs : f32
  func.return %product : f32
}

kernel.def export("hrx2_mul_mat_q8_0_f32_contiguous_c4") @hrx2_mul_mat_q8_0_f32_contiguous_c4() {
  %unit = index.constant 1 : index
  %four = index.constant 4 : index
  %rows = config.get @shape.mul_mat_q8_0_f32_contiguous_c4.rows : index
  %cols = config.get @shape.mul_mat_q8_0_f32_contiguous_c4.cols : index
  %workgroup_size = config.get @tuning.mul_mat_q8_0_f32_contiguous_c4.workgroup_size : index
  %col_groups = index.div %cols, %four : index
  kernel.launch.config workgroups(%rows, %col_groups, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch(%src0: buffer, %src1: buffer, %dst: buffer) {
  %base = index.constant 0 : offset
  %qk = index.constant 32 : index
  %block_bytes = index.constant 34 : index
  %block_f16s = index.constant 17 : index
  %qs_offset = index.constant 2 : index
  %unit = index.constant 1 : index
  %two = index.constant 2 : index
  %three = index.constant 3 : index
  %four = index.constant 4 : index
  %k = config.get @shape.mul_mat_q8_0_f32_contiguous_c4.k : index
  %rows = config.get @shape.mul_mat_q8_0_f32_contiguous_c4.rows : index
  %cols = config.get @shape.mul_mat_q8_0_f32_contiguous_c4.cols : index
  %workgroup_size = config.get @tuning.mul_mat_q8_0_f32_contiguous_c4.workgroup_size : index
  %k_bounded = index.assume %k [range(%k, 32, 32768)] : index
  %rows_bounded = index.assume %rows [range(%rows, 1, 262144)] : index
  %cols_bounded = index.assume %cols [range(%cols, 4, 4096)] : index
  %row0 = kernel.workgroup.id<x> : index
  %row = index.assume %row0 [range(%row0, 0, 262143)] : index
  %col_group = kernel.workgroup.id<y> : index
  %lane0 = kernel.workitem.id<x> : index
  %lane = index.assume %lane0 [range(%lane0, 0, 255)] : index
  %zero_f32 = scalar.constant 0.0 : f32

  %col0 = index.mul %col_group, %four : index
  %col1 = index.add %col0, %unit : index
  %col2 = index.add %col0, %two : index
  %col3 = index.add %col0, %three : index

  %blocks_per_row = index.div %k_bounded, %qk : index
  %total_blocks = index.mul %rows_bounded, %blocks_per_row : index
  %src0_i8_count = index.mul %total_blocks, %block_bytes : index
  %src0_f16_count = index.mul %total_blocks, %block_f16s : index
  %src1_count = index.mul %cols_bounded, %k_bounded : index
  %dst_count = index.mul %cols_bounded, %rows_bounded : index

  %src0_global = buffer.assume.memory_space<global> %src0 : buffer
  %src1_global = buffer.assume.memory_space<global> %src1 : buffer
  %dst_global = buffer.assume.memory_space<global> %dst : buffer
  %src0_noalias, %src1_noalias, %dst_noalias = buffer.assume.noalias %src0_global, %src1_global, %dst_global : buffer, buffer, buffer
  %src0_i8_view = buffer.view %src0_noalias[%base] : buffer -> view<[%src0_i8_count]xi8, #dense>
  %src0_f16_view = buffer.view %src0_noalias[%base] : buffer -> view<[%src0_f16_count]xf16, #dense>
  %src1_view = buffer.view %src1_noalias[%base] : buffer -> view<[%src1_count]xf32, #dense>
  %dst_view = buffer.view %dst_noalias[%base] : buffer -> view<[%dst_count]xf32, #dense>

  %row_block_base = index.mul %row, %blocks_per_row : index
  %src1_col_base0 = index.mul %col0, %k_bounded : index
  %src1_col_base1 = index.mul %col1, %k_bounded : index
  %src1_col_base2 = index.mul %col2, %k_bounded : index
  %src1_col_base3 = index.mul %col3, %k_bounded : index
  %sum0, %sum1, %sum2, %sum3 = scf.for %i = [%lane to %k_bounded step %workgroup_size](%acc0 = %zero_f32 : f32, %acc1 = %zero_f32 : f32, %acc2 = %zero_f32 : f32, %acc3 = %zero_f32 : f32) -> (f32, f32, f32, f32) {
    %block = index.div %i, %qk : index
    %in_block = index.rem %i, %qk : index
    %linear_block = index.add %row_block_base, %block : index
    %block_byte_base = index.mul %linear_block, %block_bytes : index
    %q_byte_base = index.add %block_byte_base, %qs_offset : index
    %q_byte = index.add %q_byte_base, %in_block : index
    %block_f16_base = index.mul %linear_block, %block_f16s : index
    %q = view.load %src0_i8_view[%q_byte] : view<[%src0_i8_count]xi8, #dense> -> i8
    %d_f16 = view.load %src0_f16_view[%block_f16_base] : view<[%src0_f16_count]xf16, #dense> -> f16

    %src1_index0 = index.add %src1_col_base0, %i : index
    %rhs0 = view.load %src1_view[%src1_index0] : view<[%src1_count]xf32, #dense> -> f32
    %product0 = func.apply<hrx2.q8_0_f32.c4.product>(%q, %d_f16, %rhs0) : (i8, f16, f32) -> (f32)
    %next0 = scalar.addf<reassoc|nnan|ninf|nsz> %acc0, %product0 : f32

    %src1_index1 = index.add %src1_col_base1, %i : index
    %rhs1 = view.load %src1_view[%src1_index1] : view<[%src1_count]xf32, #dense> -> f32
    %product1 = func.apply<hrx2.q8_0_f32.c4.product>(%q, %d_f16, %rhs1) : (i8, f16, f32) -> (f32)
    %next1 = scalar.addf<reassoc|nnan|ninf|nsz> %acc1, %product1 : f32

    %src1_index2 = index.add %src1_col_base2, %i : index
    %rhs2 = view.load %src1_view[%src1_index2] : view<[%src1_count]xf32, #dense> -> f32
    %product2 = func.apply<hrx2.q8_0_f32.c4.product>(%q, %d_f16, %rhs2) : (i8, f16, f32) -> (f32)
    %next2 = scalar.addf<reassoc|nnan|ninf|nsz> %acc2, %product2 : f32

    %src1_index3 = index.add %src1_col_base3, %i : index
    %rhs3 = view.load %src1_view[%src1_index3] : view<[%src1_count]xf32, #dense> -> f32
    %product3 = func.apply<hrx2.q8_0_f32.c4.product>(%q, %d_f16, %rhs3) : (i8, f16, f32) -> (f32)
    %next3 = scalar.addf<reassoc|nnan|ninf|nsz> %acc3, %product3 : f32

    scf.yield %next0, %next1, %next2, %next3 : f32, f32, f32, f32
  }

  %dot0 = kernel.workgroup.reduce<addf> %sum0 : f32
  %dot1 = kernel.workgroup.reduce<addf> %sum1 : f32
  %dot2 = kernel.workgroup.reduce<addf> %sum2 : f32
  %dot3 = kernel.workgroup.reduce<addf> %sum3 : f32
  %dst_col_base0 = index.mul %col0, %rows_bounded : index
  %dst_col_base1 = index.mul %col1, %rows_bounded : index
  %dst_col_base2 = index.mul %col2, %rows_bounded : index
  %dst_col_base3 = index.mul %col3, %rows_bounded : index
  %dst_index0 = index.add %dst_col_base0, %row : index
  %dst_index1 = index.add %dst_col_base1, %row : index
  %dst_index2 = index.add %dst_col_base2, %row : index
  %dst_index3 = index.add %dst_col_base3, %row : index
  %lane_i32 = index.cast %lane : index to i32
  %zero_i32 = scalar.constant 0 : i32
  %is_lane0 = scalar.cmpi eq, %lane_i32, %zero_i32 : i32
  scf.if %is_lane0 {
    view.store %dot0, %dst_view[%dst_index0] : f32, view<[%dst_count]xf32, #dense>
    view.store %dot1, %dst_view[%dst_index1] : f32, view<[%dst_count]xf32, #dense>
    view.store %dot2, %dst_view[%dst_index2] : f32, view<[%dst_count]xf32, #dense>
    view.store %dot3, %dst_view[%dst_index3] : f32, view<[%dst_count]xf32, #dense>
  }
  kernel.return
}

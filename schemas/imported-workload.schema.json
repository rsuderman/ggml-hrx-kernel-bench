{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ggml-hrx-kernel-bench/imported-workload.schema.json",
  "title": "GGML HRX Imported Workload",
  "type": "object",
  "required": ["schema", "source_path", "op_groups", "resolved", "unmapped"],
  "properties": {
    "schema": {
      "type": "string"
    },
    "source_path": {
      "type": "string"
    },
    "op_groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/opGroup"
      }
    },
    "resolved": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resolvedCase"
      }
    },
    "unmapped": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unmappedCase"
      }
    }
  },
  "$defs": {
    "importedCase": {
      "type": "object",
      "required": [
        "op",
        "dtype",
        "raw_case",
        "normalized_params",
        "source_path",
        "source_group_index",
        "source_case_index"
      ],
      "properties": {
        "op": { "type": "string" },
        "dtype": { "type": "object", "additionalProperties": true },
        "raw_case": { "type": "object", "additionalProperties": true },
        "normalized_params": { "type": "object", "additionalProperties": true },
        "source_path": { "type": "string" },
        "source_group_index": { "type": "integer", "minimum": 0 },
        "source_case_index": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "opGroup": {
      "type": "object",
      "required": ["op", "dtype", "source_path", "cases"],
      "properties": {
        "op": { "type": "string" },
        "dtype": { "type": "object", "additionalProperties": true },
        "source_path": { "type": "string" },
        "cases": {
          "type": "array",
          "items": { "$ref": "#/$defs/importedCase" }
        }
      },
      "additionalProperties": false
    },
    "resolvedCase": {
      "type": "object",
      "required": ["mapping_status", "imported", "kernel_family", "route_id", "params", "values"],
      "properties": {
        "mapping_status": {
          "type": "string",
          "enum": ["mapped"]
        },
        "imported": { "$ref": "#/$defs/importedCase" },
        "kernel_family": { "type": "string" },
        "route_id": { "type": ["string", "null"] },
        "params": {
          "type": "array",
          "items": { "type": "string" }
        },
        "values": {
          "type": "array",
          "items": { "type": "integer" }
        }
      },
      "additionalProperties": false
    },
    "unmappedCase": {
      "type": "object",
      "required": ["mapping_status", "reason", "candidate_kernel_families", "candidate_route_ids", "imported"],
      "properties": {
        "mapping_status": {
          "type": "string",
          "enum": ["unmapped", "ambiguous"]
        },
        "reason": {
          "type": "string",
          "enum": [
            "no_kernel_family_mapping",
            "no_dtype_mapping",
            "shape_lowering_not_implemented",
            "no_route_match",
            "ambiguous_route_match"
          ]
        },
        "detail": {
          "type": ["string", "null"]
        },
        "candidate_kernel_families": {
          "type": "array",
          "items": { "type": "string" }
        },
        "candidate_route_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "imported": { "$ref": "#/$defs/importedCase" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

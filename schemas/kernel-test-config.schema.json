{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ggml-hrx-kernel-bench/kernel-test-config.schema.json",
  "title": "GGML HRX Kernel Test Config",
  "type": "object",
  "required": ["kernel", "params", "cases"],
  "properties": {
    "kernel": {
      "type": "string"
    },
    "params": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "kernel": "copy_f32_f16",
      "params": ["nrows", "ncols"],
      "cases": [
        [1, 64],
        [1, 256]
      ]
    }
  ]
}

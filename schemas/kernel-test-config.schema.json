{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ggml-hrx-kernel-bench/kernel-test-config.schema.json",
  "title": "GGML HRX Kernel Test Config",
  "type": "object",
  "required": ["id", "op", "cases"],
  "properties": {
    "id": {
      "type": "string"
    },
    "op": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "root_symbol": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "inputs", "outputs"],
        "properties": {
          "id": {
            "type": "string"
          },
          "inputs": {
            "$ref": "#/$defs/tensorShapes"
          },
          "outputs": {
            "$ref": "#/$defs/tensorShapes"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "shape": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "integer",
        "minimum": 1
      }
    },
    "tensorShapes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/shape"
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": "copy_f32_f16",
      "op": "CPY",
      "source": "../kernels/hrx2/copy_f32_f16.loom",
      "root_symbol": "@hrx2_copy_f32_f16",
      "cases": [
        {
          "id": "copy_n64",
          "inputs": {
            "src": {
              "nrows": 1,
              "ncols": 64
            }
          },
          "outputs": {
            "dst": {
              "nrows": 1,
              "ncols": 64
            }
          }
        }
      ]
    }
  ]
}
